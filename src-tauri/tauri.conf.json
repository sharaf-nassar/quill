{
  "productName": "Quill",
  "identifier": "com.quilltoolkit.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:8181",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis", "appimage", "deb"],
    "resources": ["claude-integration/**/*"],
    "createUpdaterArtifacts": "v1Compatible",
    "macOS": {
      "entitlements": "./Entitlements.plist"
    },
    "linux": {
      "deb": {
        "desktopTemplate": "desktop-template.desktop"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQwQzVGMThBNEFBMzM5RTUKUldUbE9hTktpdkhGUUc5ZSt0VVY2QjZvQVJQbFN0akRHbXBTVGExdWtIMmhkQzE5ZjZYQTZyV1oK",
      "endpoints": [
        "https://github.com/sharaf-nassar/quill/releases/latest/download/latest.json"
      ]
    }
  },
  "app": {
    "enableGTKAppId": true,
    "windows": [
      {
        "title": "Quill",
        "width": 280,
        "height": 340,
        "minWidth": 240,
        "minHeight": 200,
        "alwaysOnTop": false,
        "transparent": true,
        "decorations": false,
        "resizable": true
      }
    ]
  }
}
